# ── SOLVENT config ───────────────────────────────────────────────
# Copy this file to .env and fill it in. Without keys the project runs on mock data.

# Stripe TEST MODE key (starts with sk_test_ or rk_test_). No real money moves.
# Get it at: dashboard.stripe.com → Developers → API keys → Test mode
STRIPE_SECRET_KEY=

# Discount hard cap (fraction). The agent can NEVER exceed this — enforced in code.
DISCOUNT_CAP=0.15

# Telegram approvals (optional — leave blank to log approvals to the console)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Models (live calls) ──
# Nous Hermes — picks the recovery stage + drafts the message. Key from portal.nousresearch.com
NOUS_API_KEY=
# NVIDIA Nemotron Content Safety — screens the message text. Key from build.nvidia.com (nvapi-...)
NVIDIA_API_KEY=
